# =============================================================================
# OVERLAND INTELLIGENCE SYSTEM — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values.
# Never commit .env to version control.
#
# This file is the single source of truth for all provider and model config.
# To switch providers or models — change values here only, no code changes needed.
# To activate a commented-out provider — uncomment its block and set the values.
# =============================================================================


# -----------------------------------------------------------------------------
# LLM PROVIDER
# Options: groq | ollama_primary | ollama_secondary | openai
# -----------------------------------------------------------------------------
LLM_PROVIDER=groq

# Groq — fast inference, generous free tier
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# Ollama — local models, zero cost, no API key required
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL_PRIMARY=llama3.2
OLLAMA_MODEL_SECONDARY=mistral

# OpenAI — uncomment to activate, set LLM_PROVIDER=openai_primary above
# OPENAI_API_KEY=your_openai_api_key_here
# OPENAI_MODEL_PRIMARY=gpt-4o
# OPENAI_MODEL_SECONDARY=gpt-4o-mini
# OPENAI_BASE_URL=                        # optional — for Azure or compatible endpoints


# -----------------------------------------------------------------------------
# EMBEDDINGS PROVIDER
# Options: ollama | openai | huggingface
# -----------------------------------------------------------------------------
# Local development
EMBEDDING_PROVIDER=ollama
EMBEDDING_MODEL=nomic-embed-text

# Production (Render)
# EMBEDDING_PROVIDER=huggingface
# EMBEDDING_MODEL=all-MiniLM-L6-v2

# OpenAI embeddings — uncomment to activate, set EMBEDDING_PROVIDER=openai above
# EMBEDDING_MODEL=text-embedding-3-small
# (OPENAI_API_KEY is shared with the LLM block above)


# -----------------------------------------------------------------------------
# SEARCH PROVIDER
# Options: tavily | duckduckgo | brave
# -----------------------------------------------------------------------------
SEARCH_PROVIDER=tavily

# Tavily — best quality results, 1k free searches/month
TAVILY_API_KEY=your_tavily_api_key_here

# Brave Search — 2k free/month, uncomment to activate, set SEARCH_PROVIDER=brave above
# BRAVE_API_KEY=your_brave_api_key_here

# DuckDuckGo — unlimited, no key required


# -----------------------------------------------------------------------------
# APPLICATION
# -----------------------------------------------------------------------------
APP_NAME=Overland Intelligence System
APP_VERSION=1.0.0
USER_AGENT=OverlandIntelBot/1.0
LOG_LEVEL=INFO
OUTPUT_DIR=output/reports
MAX_ROWS=50000
SUGGESTED_QUESTION_COUNT=5

# RAG tuning parameters
RAG_CHUNK_SIZE=500
RAG_CHUNK_OVERLAP=50
RAG_TOP_K=5
