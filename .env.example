# =============================================================================
# OVERLAND INTELLIGENCE SYSTEM — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values.
# Never commit .env to version control.
# =============================================================================


# -----------------------------------------------------------------------------
# LLM PROVIDER
# Options: groq | ollama
# groq  — fast, free tier, requires API key
# ollama — local, unlimited, requires Ollama running on your machine
# -----------------------------------------------------------------------------
LLM_PROVIDER=groq

# Groq (active default — free tier, fast inference)
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# Ollama (local fallback — unlimited, no key required)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL_PRIMARY=llama3.2
OLLAMA_MODEL_SECONDARY=mistral

# OpenAI (showcased — built and ready, commented out by default)
# Uncomment OPENAI lines in config/llm_factory.py to activate
# OPENAI_API_KEY=your_openai_api_key_here
# OPENAI_MODEL=gpt-4o


# -----------------------------------------------------------------------------
# EMBEDDING PROVIDER
# Options: ollama
# nomic-embed-text runs locally via Ollama — no API cost on document chunks
# -----------------------------------------------------------------------------
EMBEDDING_PROVIDER=ollama
EMBEDDING_MODEL=nomic-embed-text


# -----------------------------------------------------------------------------
# SEARCH PROVIDER
# Options: tavily | duckduckgo
# Controlled via Streamlit sidebar at runtime — this sets the default
# tavily     — best results, 1k free searches/mo, requires API key
# duckduckgo — unlimited, no key, use when Tavily quota is exhausted
# brave      — 2k free/mo, requires API key (built, showcased in code)
# -----------------------------------------------------------------------------
SEARCH_PROVIDER=tavily

# Tavily (active default)
TAVILY_API_KEY=your_tavily_api_key_here

# Brave Search (showcased — built and ready, swap SEARCH_PROVIDER to activate)
# BRAVE_API_KEY=your_brave_api_key_here


# -----------------------------------------------------------------------------
# APPLICATION
# -----------------------------------------------------------------------------
APP_NAME=Overland Intelligence System
APP_VERSION=1.0.0
USER_AGENT=OverlandIntelBot/1.0
LOG_LEVEL=INFO

# Report output directory (relative to project root)
OUTPUT_DIR=output/reports

# Maximum rows to analyze from uploaded CSV (performance guard)
MAX_ROWS=50000

# Number of suggested questions to generate on CSV upload
SUGGESTED_QUESTION_COUNT=5

# RAG chunk settings
RAG_CHUNK_SIZE=500
RAG_CHUNK_OVERLAP=50
RAG_TOP_K=5